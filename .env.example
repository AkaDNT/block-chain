# Blockchain Configuration
WEB3_INFURA_PROJECT_ID=your_infura_project_id_here
PRIVATE_KEY=your_private_key_here

# IPFS Configuration
IPFS_API_URL=http://127.0.0.1:5001
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here

# Frontend Configuration
VITE_CONTRACT_ADDRESSES_FILE=/deployment.json
VITE_DEFAULT_NETWORK=ethereum:local:geth-dev

# Development Settings
DEBUG=true
LOG_LEVEL=info

# Optional: Custom RPC URLs
ETHEREUM_MAINNET_RPC=https://mainnet.infura.io/v3/${WEB3_INFURA_PROJECT_ID}
ETHEREUM_SEPOLIA_RPC=https://sepolia.infura.io/v3/${WEB3_INFURA_PROJECT_ID}
ETHEREUM_LOCAL_RPC=http://127.0.0.1:8545
