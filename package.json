{
  "name": "community-dao-blockchain",
  "version": "2.0.0",
  "description": "DAO governance project with ERC-20 voting, NFT membership, IPFS proposal storage, and Vue frontend.",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy-dao.js --network localhost",
    "deploy:hardhat": "hardhat run scripts/deploy-dao.js",
    "frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.19"
  }
}
